# Copy this file to .env and fill in your real Supabase password.
# .env is gitignored and must never be committed.

# Async driver — used by db.py / FastAPI server at runtime
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# Sync driver — used by Alembic migrations
ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# Set to "development" to enable localhost fallback when DATABASE_URL is missing
ENV=development
